{
  "name": "component-library-vue",
  "version": "0.2.0",
  "description": "Accessible Vue 3 components built with Reka UI, SCSS design tokens, and Vite+.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vp test run",
    "check": "vp check",
    "pack:local": "vp run build && vp pm pack --out .local-pack/component-library-vue.tgz",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.2",
    "reka-ui": "^2.10.1"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-vitest": "^10.5.3",
    "@storybook/vue3-vite": "^10.5.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/browser-playwright": "^4.1.10",
    "@vue/tsconfig": "^0.9.1",
    "playwright": "^1.61.1",
    "sass": "^1.101.3",
    "storybook": "^10.5.3",
    "typescript": "~6.0.0",
    "unplugin-vue": "^7.2.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5",
    "vite-plus": "^0.2.4",
    "vue": "^3.5.40",
    "vue-tsc": "^3.3.7"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  },
  "engines": {
    "node": "^24.12.0 || >=26.0.0"
  },
  "packageManager": "bun@1.3.14"
}
